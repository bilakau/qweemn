*.env.*

# Editors
.vscode/
.idea/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
.ENV
.python-version

# Compiled files
*.o
*.obj
*.so
*.a
*.dll
*.exe
*.out

# Coverage
.coverage
coverage/
htmlcov/

# Cache
.cache/
.mypy_cache/
.pytest_cache/
.nyc_output/
coverage/

# OS
.DS_Store
Thumbs.db

# Compression
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
